{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rockchip Universal Imager",
  "version": "0.1.0",
  "identifier": "com.rockchipuniversalimager.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rockchip Universal Imager",
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [],
    "externalBin": []
  }
}
